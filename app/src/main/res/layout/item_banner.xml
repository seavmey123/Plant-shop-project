<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardBackgroundColor="#DDFFE3"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- Left Content -->
        <LinearLayout
            android:layout_width="159dp"
            android:layout_height="144dp"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_banner_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Up to 20% Offer Sale"
                android:textColor="#1B2D1C"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_banner_sub"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:lineSpacingMultiplier="1.4"
                android:text="Enjoy shopping with our special PlanShop offer"
                android:textColor="#4CAF50"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_shop_now"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_btn_green"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Shop Now"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right Image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_banner"
            android:layout_width="178dp"
            android:layout_height="174dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            android:scaleType="centerCrop"
            android:src="@drawable/banner_1"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.MediumComponent"/>

    </RelativeLayout>

</androidx.cardview.widget.CardView>